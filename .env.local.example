# Notion Integration Token
# Get this from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database IDs
# Get these from the database URL: https://notion.so/{database_id}?v=...
# Or from Share > Copy link > Extract the ID

# Timeline Database (生活时间线)
NOTION_TIMELINE_DB=

# Fragments Database (碎片化记录)
NOTION_FRAGMENTS_DB=

# Tech Notes Database (技术笔记)
NOTION_NOTES_DB=

# Demos Database (Demo展示)
NOTION_DEMOS_DB=
